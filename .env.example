# Copy this file to .env and fill in your actual API keys and tokens which you might use in the experiments.
HF_TOKEN="your-hugging-face-token"
ANTHROPIC_API_KEY="your-anthropic-api-key"
GEMINI_API_KEY="your-gemini-api-key"
OPENAI_API_KEY="your-openai-api-key"
GOOGLE_API_KEY="your-google-api-key"
HUGGING_FACE_HUB_TOKEN="your-hugging-face-token"

# Google Vertex AI Configuration (required for Gemini instruction reward with logprobs)
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
# GOOGLE_CLOUD_LOCATION="us-central1"  # Optional, defaults to us-central1
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"  # Optional, for service account auth
